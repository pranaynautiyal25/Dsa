            for(int j=i+1;j<nums.size();j++){
                for(int k=j+1;k<nums.size();k++){
                    if(nums[i]==nums[j]&&nums[i]==nums[k]&&nums[j]==nums[k]){
                        out=min(out,abs(i-j)+abs(i-k)+abs(k-j));
                    }
                }
            }
        }
if(out==INT_MAX){
    return -1;
}
        return out;
    }
};
