//leetcode 3212

class Solution {
public:


    int numberOfSubmatrices(vector<vector<char>>& grid) {
        vector<vector<vector<int>>> v(grid.size(),vector<vector<int>>(grid[0].size(),vector<int>(2,0)));

        for(int i=0;i<grid.size();i++){
            int x=0;
            int y=0;

            for(int j=0;j<grid[0].size();j++){
                if(grid[i][j]=='X'){
                    x++;
                }
                if(grid[i][j]=='Y'){
                    y++;
                }

                v[i][j][0]=x;
                v[i][j][1]=y;
            }
        }

        for(int i=1;i<grid.size();i++){
            for(int j=0;j<grid[0].size();j++){
                v[i][j][0]+=v[i-1][j][0];
                v[i][j][1]+=v[i-1][j][1];

                
            }

        }

        int out=0;
        for(int i=0;i<grid.size();i++){
            for(int j=0;j<grid[0].size();j++){
                if(v[i][j][0]==v[i][j][1]&&v[i][j][0]!=0){
                    out++;
                }
            }
        }

        return out++;
    }
};


//1466

class Solution {
public:
void dfs(unordered_map<int,unordered_map<int,int>> &real,unordered_map<int,vector<int>> &all,vector<int> &v,int s,int &c){

    if(v[s]==1){
        return;
    }
    //cout<<s<<"-";
    v[s]=1;

    vector<int> p=all[s];

    for(int i=0;i<p.size();i++){
        if(v[p[i]]==1){
            continue;
        }
        if(real[s][p[i]]==1){
            c++;
            cout<<0;
        }
        //cout<<p[i]<<" ";
        dfs(real,all,v,p[i],c);
    }
    cout<<endl;
}
    int minReorder(int n, vector<vector<int>>& connections) {
        unordered_map<int,vector<int>> all;

        unordered_map<int,unordered_map<int,int>> real;
        for(int i=0;i<connections.size();i++){
            real[connections[i][0]][connections[i][1]]=1;
            all[connections[i][1]].push_back(connections[i][0]);
            all[connections[i][0]].push_back(connections[i][1]);
        }

        vector<int> v(n,0);
        int out=0;
        dfs(real,all,v,0,out);

        return out;
    }
};

//3653
class Solution {
public:
    int xorAfterQueries(vector<int>& nums, vector<vector<int>>& queries) {
        
        int out;
        long long m=1e9+7;

        for(int i=0;i<queries.size();i++){
            int idx=queries[i][0];
            int r=queries[i][1];
            long long v=queries[i][3];
            int k=queries[i][2];

            while(idx<=r){
                long long p=nums[idx];
                long long w=p*v;
                w=w%m;
                //cout<<w<<" ";
                nums[idx]=w;                
                idx+=k;
            }
        }
        out= nums[0];
        for(int i=1;i<nums.size();i++){
            //cout<<nums[i]<<" ";
            out^=nums[i];
        }

        return out;
    }
};


